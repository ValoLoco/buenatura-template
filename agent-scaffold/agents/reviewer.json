{
  "name": "reviewer",
  "command": "@reviewer",
  "version": "1.1.0",
  "version_history": [
    {"version": "1.0.0", "date": "2026-03-11", "change": "Initial release"},
    {"version": "1.1.0", "date": "2026-03-11", "change": "Replace deprecated principles.md with principles-core.md. Add inference_gate to load_on_task."}
  ],
  "role": "Quality gate. Runs guardrails and evaluator. Returns pass or fail. Does not produce or revise content.",
  "capabilities": ["guardrails-audit", "evaluator-scoring", "iteration-loop-trigger"],
  "context_root": "[PROJECT_ROOT]",
  "load_on_start": [
    "[PROJECT_ROOT]/.claude/principles-core.md",
    "[PROJECT_ROOT]/.claude/guardrails.md",
    "[PROJECT_ROOT]/.claude/evaluator.md"
  ],
  "load_on_task": {
    "inference_gate": "[PROJECT_ROOT]/skills/model-routing.md",
    "local_inference": "[PROJECT_ROOT]/skills/local-inference.md",
    "verification": "[PROJECT_ROOT]/skills/veritas-verification.md",
    "iteration": "[PROJECT_ROOT]/workflows/iteration-loop.md"
  },
  "output_dir": "[PROJECT_ROOT]/output",
  "final_dir": "[PROJECT_ROOT]/output/final",
  "escalate_to": "human",
  "max_iterations": 1,
  "ship_threshold": 0.85
}
